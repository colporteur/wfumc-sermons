# Copy this file to .env.local and fill in the values from your Supabase project.
# These are the SAME values as the bulletin app — both apps share one backend.
# .env.local is gitignored — never commit real keys.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-jwt-string

# For GitHub Pages deploy, set this to "/<your-repo-name>/" — e.g. "/wfumc-sermons/".
# Leave commented out for local dev so it defaults to "/".
# VITE_BASE_PATH=/wfumc-sermons/
